NODE_ENV=production
PORT=8080
MONGODB_URI=mongodb://localhost:27017/bucketlist
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
APP_URL=https://your-domain.example

# Set MOCK_EMAIL=true to log invite emails instead of sending.
MOCK_EMAIL=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=no-reply@your-domain.example
GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
